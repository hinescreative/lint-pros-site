---
import { trustItems } from "../data/site";
---
<section class="trust" aria-label="Credentials">
  <ul class="trust__list">
    {trustItems.map((it) => (
      <li class="trust__item">
        <span class="trust__check" aria-hidden="true">
          <svg viewBox="0 0 14 14" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 7.5L5.5 11L12 3.5" />
          </svg>
        </span>
        <span class="trust__body">
          <span class="trust__label">{it.label}</span>
          <span class="trust__sub">{it.sub}</span>
        </span>
      </li>
    ))}
  </ul>
</section>

<style>
  .trust {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--spacing-6) var(--container-pad);
  }

  .trust__list {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--spacing-6);
    list-style: none;
    padding: 0;
  }

  .trust__item {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
  }

  .trust__check {
    width: 26px;
    height: 26px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: var(--color-teal-dim);
    color: var(--color-teal);
    flex-shrink: 0;
  }

  .trust__body {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .trust__label {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-ink);
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .trust__sub {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-faint);
    margin-top: 2px;
  }

  @media (max-width: 960px) {
    .trust__list { grid-template-columns: repeat(3, 1fr); row-gap: var(--spacing-4); }
  }
  @media (max-width: 560px) {
    .trust__list { grid-template-columns: repeat(2, 1fr); }
  }
</style>
