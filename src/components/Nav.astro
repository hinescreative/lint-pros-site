---
import { site } from "../data/site";
---
<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__brand" aria-label={`${site.name} - home`}>
      <img src="/lintpros-assets/logo.jpg" alt={site.name} class="nav__logo" width="586" height="528" />
      <div class="nav__brand-copy">
        <span class="nav__brand-line">Fox River Grove, IL</span>
        <span class="nav__brand-sub">Dryer vent cleaning</span>
      </div>
    </a>
    <nav class="nav__links" aria-label="Primary">
      <a href="/services/">Services</a>
      <a href="/service-areas/">Service Areas</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>
    <a href={site.phoneHref} class="nav__call">
      <span class="nav__call-label">Call</span>
      <span class="nav__call-number">{site.phone}</span>
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(32, 25, 21, 0.94);
    border-bottom: 1px solid rgba(240, 197, 58, 0.22);
    backdrop-filter: blur(10px) saturate(130%);
  }

  .nav__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--spacing-4) var(--container-pad);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--spacing-6);
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-4);
  }

  .nav__logo {
    height: 72px;
    width: auto;
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 12px 28px -18px rgba(0, 0, 0, 0.7);
  }

  .nav__brand-copy {
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 0.25rem;
  }

  .nav__brand-line {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
  }

  .nav__brand-sub {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .nav__links {
    display: flex;
    gap: var(--spacing-8);
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: var(--text-sm);
  }

  .nav__links a {
    color: rgba(255, 255, 255, 0.88);
    padding: var(--spacing-2) 0;
    position: relative;
    transition: color 200ms ease;
  }

  .nav__links a:hover {
    color: var(--color-navy);
  }

  .nav__call {
    background: var(--color-teal);
    color: #fff;
    padding: var(--spacing-3) var(--spacing-6);
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    display: inline-flex;
    flex-direction: column;
    line-height: 1.1;
    text-align: right;
    transition: background 200ms ease;
  }

  .nav__call:hover {
    background: var(--color-teal-hover);
  }

  .nav__call-label {
    font-size: 0.7rem;
    font-weight: 500;
    opacity: 0.9;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .nav__call-number {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .nav__links { display: none; }
  }

  @media (max-width: 560px) {
    .nav__call-label { display: none; }
    .nav__brand-copy { display: none; }
    .nav__logo { height: 58px; }
  }
</style>
